{
  "manifest_version": 3,
  "name": "Super PDF Translator",
  "version": "2.1",
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "permissions": [
    "sidePanel",
    "storage",
    "tabs",
    "commands",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://translate.googleapis.com/*"
  ],
  "commands": {
    "open_side_panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "사이드 패널 열기"
    },
    "switch_tab_next": {
      "suggested_key": {
        "default": "Ctrl+Shift+Right",
        "mac": "Command+Shift+Right"
      },
      "description": "다음 탭으로 전환"
    }
  }
}